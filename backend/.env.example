# Template do .env do backend. Copie este arquivo para `.env` e preencha
# com seus valores reais. O `.env` é gitignored — nunca commit secrets.
#
#   cp backend/.env.example backend/.env
#
# Em produção (Coolify/Docker), configure essas vars no painel da plataforma
# em vez de manter o `.env` versionado.

# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# ─── Firecrawl ────────────────────────────────────────────────────────────────
FIRECRAWL_API_KEY=

# ─── Kiwify Webhook ───────────────────────────────────────────────────────────
KIWIFY_WEBHOOK_SECRET=

# ─── E-mail (SMTP) ────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Client4You
SMTP_USE_TLS=true

# ─── URLs ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=

# ─── Cloudflare Turnstile (CAPTCHA) ───────────────────────────────────────────
TURNSTILE_SECRET_KEY=

# ─── Ambiente ─────────────────────────────────────────────────────────────────
# 'development' permite fallbacks de auth em falhas (dev local).
# 'production' faz a auth FALHAR FECHADO em qualquer erro de validação JWT.
ENVIRONMENT=development

# ─── Encryption Key ───────────────────────────────────────────────────────────
# Chave Fernet (32 bytes base64 URL-safe) usada pra encriptar senhas SMTP
# em email_accounts.smtp_pass_encrypted. Gere com:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# NUNCA mude essa chave depois de ter senhas encriptadas — todas viram lixo.
ENCRYPTION_KEY=

# ─── Admin ────────────────────────────────────────────────────────────────────
ADMIN_IP_WHITELIST=

# ─── Rate Limiting (anti brute-force) ─────────────────────────────────────────
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_DURATION=1800
LOGIN_WINDOW_DURATION=900

