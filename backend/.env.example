# Template do .env do backend. Copie este arquivo para `.env` e preencha
# com seus valores reais. O `.env` é gitignored — nunca commit secrets.
#
#   cp backend/.env.example backend/.env
#
# Em produção (Coolify/Docker), configure essas vars no painel da plataforma
# em vez de manter o `.env` versionado.

# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
# Opcional: o backend usa SUPABASE_SERVICE_ROLE_KEY; cai em SUPABASE_KEY como
# fallback se a primeira estiver ausente. Defina só se não usar a service role.
SUPABASE_KEY=

# ─── Fonte de descoberta de leads ─────────────────────────────────────────────
# dataforseo (default, produção — ver ADR-002) | serper | scrappa (dev/teste)
LEAD_SOURCE=dataforseo

# ─── DataForSEO (descoberta de leads — Google Maps) ───────────────────────────
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
# Base URL da API (inclui /v3). Sandbox = https://sandbox.dataforseo.com/v3
DATAFORSEO_BASE_URL=https://api.dataforseo.com/v3

# ─── Serper.dev (descoberta alternativa de dev/teste; só se LEAD_SOURCE=serper) ─
# Chave em https://serper.dev — ~20 places/chamada, 3 créditos/query, sem paginação.
SERPER_API_KEY=

# ─── Scrappa.co (descoberta alternativa de dev/teste; só se LEAD_SOURCE=scrappa) ─
# Chave em https://scrappa.co/dashboard — até 200 results/request, 1 crédito/request,
# 500 créditos/mês RECORRENTE grátis. Melhor tier grátis pra teste durável.
SCRAPPA_API_KEY=

# ─── Firecrawl (enrichment de e-mail) ─────────────────────────────────────────
FIRECRAWL_API_KEY=
FIRECRAWL_BASE_URL=https://api.firecrawl.dev/v1
# TTL (dias) do cache global de e-mail por domínio
EMAIL_CACHE_TTL_DAYS=30

# ─── Receita Federal (CNPJ → metadados) ───────────────────────────────────────
BRASIL_API_CNPJ_BASE=https://brasilapi.com.br/api/cnpj/v1

# ─── Toggles dos providers de enrichment (default: ligados) ───────────────────
ENABLE_DATAFORSEO_CONTACT_URL_PROVIDER=true
ENABLE_FIRECRAWL_SEARCH_PROVIDER=true
ENABLE_FIRECRAWL_MAP_SCRAPE_PROVIDER=true
ENABLE_RECEITA_FEDERAL_PROVIDER=true

# ─── Feature flag: Campanhas de Email ─────────────────────────────────────────
# default off. Reativar exige também VITE_ENABLE_CAMPAIGNS=true no frontend.
# Ver docs/FEATURE_FLAGS.md.
ENABLE_CAMPAIGNS=false

# ─── Kiwify Webhook ───────────────────────────────────────────────────────────
KIWIFY_WEBHOOK_SECRET=

# ─── E-mail (SMTP) ────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Client4You
SMTP_USE_TLS=true

# ─── URLs ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=

# ─── Cloudflare Turnstile (CAPTCHA) ───────────────────────────────────────────
TURNSTILE_SECRET_KEY=

# ─── Ambiente ─────────────────────────────────────────────────────────────────
# 'development' permite fallbacks de auth em falhas (dev local).
# 'production' faz a auth FALHAR FECHADO em qualquer erro de validação JWT.
ENVIRONMENT=development

# ─── Encryption Key ───────────────────────────────────────────────────────────
# Chave Fernet (32 bytes base64 URL-safe) usada pra encriptar senhas SMTP
# em email_accounts.smtp_pass_encrypted. Gere com:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# NUNCA mude essa chave depois de ter senhas encriptadas — todas viram lixo.
ENCRYPTION_KEY=

# ─── Admin ────────────────────────────────────────────────────────────────────
ADMIN_IP_WHITELIST=

# ─── Rate Limiting (anti brute-force) ─────────────────────────────────────────
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_DURATION=1800
LOGIN_WINDOW_DURATION=900

# ─── Workers ──────────────────────────────────────────────────────────────────
# email_worker/enrichment_worker usam dedup in-memory e exigem 1 worker uvicorn.
# Só altere após migrar pra Celery/Redis — ver docs/TECH_DEBT.md#3.
UVICORN_WORKER_COUNT=1

