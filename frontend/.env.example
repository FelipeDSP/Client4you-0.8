# Template do .env do frontend. Copie este arquivo para `.env` e preencha.
#
#   cp frontend/.env.example frontend/.env
#
# Em produção, essas vars são injetadas como build args no Dockerfile
# pelo docker-compose.yml. Apenas anon/publishable keys devem viver aqui —
# nunca service_role.

# URL do backend FastAPI. Em dev local o Vite faz proxy de /api para a porta
# 8001 (ver vite.config.ts), então pode ficar vazio. Em prod = domínio do backend.
VITE_BACKEND_URL=http://localhost:8001

# Supabase — Project Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=

# Feature flag: módulo de Campanhas de Email (default desligado).
# DEVE espelhar ENABLE_CAMPAIGNS do backend — ver docs/FEATURE_FLAGS.md.
VITE_ENABLE_CAMPAIGNS=false
