# Template do .env do frontend. Copie este arquivo para `.env` e preencha.
#
#   cp frontend/.env.example frontend/.env
#
# Em produção, essas vars são injetadas como build args no Dockerfile
# pelo docker-compose.yml. Apenas anon/publishable keys devem viver aqui —
# nunca service_role.

# URL do backend FastAPI (dev = localhost, prod = domínio do backend)
VITE_BACKEND_URL=http://localhost:8000

# Supabase — Project Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# Cloudflare Turnstile (CAPTCHA) — dash.cloudflare.com → Turnstile → Site Key
VITE_TURNSTILE_SITE_KEY=

# Legado (mantido para compatibilidade com build args)
REACT_APP_BACKEND_URL=http://localhost:8000
